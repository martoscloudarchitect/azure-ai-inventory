# =============================================================================
# AzurePrism Environment Configuration
# Ordered by runtime flow: Identity -> AI Auth/Model -> Report Profile ->
# Inventory Extraction Scale -> Token Controls.
# =============================================================================

# -----------------------------------------------------------------------------
# 1) Azure Identity (required)
# Impact: defines tenant context for az login and resource visibility.
# -----------------------------------------------------------------------------
AZURE_TENANT_ID=

# -----------------------------------------------------------------------------
# 2) Azure OpenAI / AI Foundry Model Settings
# Impact: controls model behavior, quality, and cost profile.
# -----------------------------------------------------------------------------
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-5.4-mini

# -----------------------------------------------------------------------------
# 3) Azure OpenAI Authentication (choose ONE mode)
# Impact: enables AI report generation. If endpoint is missing, run is inventory-only.
#
# Option 1: API Key mode:
#   - set AZURE_OPENAI_ENDPOINT + AZURE_OPENAI_API_KEY
#   - regional or custom-subdomain endpoint accepted
#
# Option 2: Keyless mode (current):
#   - set AZURE_OPENAI_ENDPOINT, leave AZURE_OPENAI_API_KEY empty
#   - requires custom-subdomain endpoint and proper RBAC role assignment
# -----------------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://<YOUR_RESOURCE>.openai.azure.com/
# AZURE_OPENAI_API_KEY=<your-api-key>
AZURE_OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# 4) Report Profile Selection
# Impact: determines the deep-dive assessment lens in Phase 2.
# Valid values: architecture, bcdr, security, observability, governance,
# networking, defender
# -----------------------------------------------------------------------------
PROMPT_PROFILE=architecture

# -----------------------------------------------------------------------------
# 5) Inventory Extraction Scale Control
# Impact: pagination behavior when querying Resource Graph.
# Default 500; Azure maximum 1000.
# -----------------------------------------------------------------------------
RESOURCE_GRAPH_PAGE_SIZE=500

# -----------------------------------------------------------------------------
# 6) Token Controls (report-size and overflow behavior)
# Impact: controls output depth and token safety guards.
#
# Completion token caps:
#   - BRIEF: Phase 1 Environment Brief length
#   - DOC: Phase 2 narrative report depth
#   - MERMAID: diagram detail budget
#
# Input guardrail:
#   - AZURE_OPENAI_MAX_INPUT_TOKENS is a pre-call hard ceiling.
#   - If estimated input exceeds this value (example: 343072 > 272000),
#     the run is rejected early with ValueError.
#   - This does NOT change sampling aggressiveness by itself.
#
# Token accounting clarity (per AI call and per execution):
#   - input_tokens      = prompt tokens sent to the model
#   - output_tokens     = completion tokens returned by the model
#   - total_tokens      = input_tokens + output_tokens
#   - project_total     = sum(total_tokens across all AI calls in the run)
#
# Where to validate after each run:
#   - data_export/<timestamp>_<profile>/token_usage.json
#     (contains prompt_tokens, completion_tokens, total_tokens per call)
# -----------------------------------------------------------------------------
AZURE_OPENAI_BRIEF_MAX_COMPLETION_TOKENS=2000
AZURE_OPENAI_DOC_MAX_COMPLETION_TOKENS=25000
AZURE_OPENAI_MERMAID_MAX_COMPLETION_TOKENS=8000
AZURE_OPENAI_MAX_INPUT_TOKENS=272000
