# Set the Azure tenant used by az login.
AZURE_TENANT_ID=

# Azure OpenAI / AI Foundry — see README.md for full authentication guide.
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-5.4-mini

# AUTHENTICATION — choose ONE option. (Details and examples in README.md)
# Option 1: API Key   → set ENDPOINT + API_KEY.   Accepts regional or custom-subdomain endpoints.
# Option 2: Keyless   → set ENDPOINT, leave API_KEY empty.  Requires custom-subdomain endpoint.

# Active configuration:
AZURE_OPENAI_ENDPOINT=https://<YOUR_RESOURCE>.openai.azure.com/
# Option 1: API Key
#AZURE_OPENAI_API_KEY=
# Option 2: Keyless
AZURE_OPENAI_API_KEY=

# Token limits (defaults shown). See README.md → Configuration for details.
AZURE_OPENAI_BRIEF_MAX_COMPLETION_TOKENS=2000
AZURE_OPENAI_DOC_MAX_COMPLETION_TOKENS=25000
AZURE_OPENAI_MERMAID_MAX_COMPLETION_TOKENS=8000

# Resource Graph page size. Default 500, Azure max 1000.
RESOURCE_GRAPH_PAGE_SIZE=500
