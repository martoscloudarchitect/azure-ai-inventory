# Set the Azure tenant used by az login.
AZURE_TENANT_ID=

# Azure OpenAI / AI Foundry settings used to generate the documentation.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=

# Token limits for each AI generation stage.

# BRIEF  = Phase 1 Environment Brief (default 2000).
AZURE_OPENAI_BRIEF_MAX_COMPLETION_TOKENS=2000

# DOC    = Phase 2 deep-dive report narrative (default 25000).
AZURE_OPENAI_DOC_MAX_COMPLETION_TOKENS=25000

# MERMAID = Phase 2 Mermaid diagram (default 8000).
AZURE_OPENAI_MERMAID_MAX_COMPLETION_TOKENS=8000

# Max resources per Azure Resource Graph page (pagination handles all pages automatically).
# Azure enforces a hard cap of 1000. Default is 500 for broad tenant compatibility.
# Increase toward 1000 for faster collection on tenants that support it.
RESOURCE_GRAPH_PAGE_SIZE=500
